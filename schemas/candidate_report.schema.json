{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "metrics",
    "pages",
    "notes"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "metrics": {
      "type": "object"
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
