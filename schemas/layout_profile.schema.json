{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LayoutProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "page_count",
    "pages"
  ],
  "properties": {
    "page_count": {
      "type": "integer",
      "minimum": 1
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "page_index",
          "page_type",
          "confidence",
          "bands"
        ],
        "properties": {
          "page_index": {
            "type": "integer",
            "minimum": 0
          },
          "page_type": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "bands": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "x0",
                "x1",
                "confidence"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "x0": {
                  "type": "number"
                },
                "x1": {
                  "type": "number"
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
