{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PageIR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "page_index",
    "width",
    "height",
    "words",
    "lines"
  ],
  "properties": {
    "page_index": {
      "type": "integer",
      "minimum": 0
    },
    "width": {
      "type": "number"
    },
    "height": {
      "type": "number"
    },
    "words": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "word_id",
          "page",
          "text",
          "x0",
          "y0",
          "x1",
          "y1",
          "is_struck",
          "strike_coverage",
          "strike_sources",
          "strike_min_center_delta"
        ],
        "properties": {
          "word_id": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 0
          },
          "text": {
            "type": "string"
          },
          "x0": {
            "type": "number"
          },
          "y0": {
            "type": "number"
          },
          "x1": {
            "type": "number"
          },
          "y1": {
            "type": "number"
          },
          "is_struck": {
            "type": "boolean"
          },
          "strike_coverage": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "strike_sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "strike_min_center_delta": {
            "type": [
              "number",
              "null"
            ]
          }
        }
      }
    },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "line_id",
          "page",
          "text",
          "bbox",
          "word_ids",
          "confidence"
        ],
        "properties": {
          "line_id": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 0
          },
          "text": {
            "type": "string"
          },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "number"
            }
          },
          "word_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "segment_hint": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
